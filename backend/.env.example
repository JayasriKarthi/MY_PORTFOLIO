# --- Server ---
PORT=5000
NODE_ENV=development

# --- Database (MongoDB Atlas connection string) ---
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/portfolio?retryWrites=true&w=majority

# --- Auth ---
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Admin login credentials (used once by the seed script to create your admin user)
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=choose_a_strong_password

# --- File storage ---
# Uploaded files (resume, certificate badges) save to backend/uploads/ and are
# served from this base URL. Leave as-is for local development.
PUBLIC_BASE_URL=http://localhost:5000

# --- CORS ---
CLIENT_ORIGIN=http://localhost:5173
